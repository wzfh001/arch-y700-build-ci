#!/usr/bin/bash
set -euo pipefail
umask 077

redactor=${TB321FU_REDACTOR:-/usr/local/libexec/tb321fu-redact-support-bundle}
timestamp=$(date -u +%Y%m%dT%H%M%SZ)
target_user=${SUDO_USER:-${USER:-fuhao}}
target_home=$(getent passwd "$target_user" 2>/dev/null | cut -d: -f6 || true)
[ -n "$target_home" ] || target_home=${HOME:-/tmp}
destination=${1:-$target_home/Downloads}
mkdir -p -- "$destination"
[ -x "$redactor" ] || {
  printf 'support bundle redactor is missing or not executable: %s\n' "$redactor" >&2
  exit 1
}

work=$(mktemp -d "${TMPDIR:-/tmp}/tb321fu-support.${timestamp}.XXXXXX")
trap 'rm -rf -- "$work"' EXIT

note() {
  printf '%s\n' "$*" >> "$work/COLLECTION-NOTES.txt"
}

collect() {
  local name=$1
  shift
  {
    printf '$'
    printf ' %q' "$@"
    printf '\n\n'
    timeout 45s "$@"
  } > "$work/$name.txt" 2>&1 || note "$name: command failed or timed out"
}

collect_shell() {
  local name=$1
  local command=$2
  {
    printf '$ %s\n\n' "$command"
    timeout 45s /usr/bin/bash -o pipefail -c "$command"
  } > "$work/$name.txt" 2>&1 || note "$name: command failed or timed out"
}

collect_privileged_shell() {
  local name=$1
  local command=$2
  if [ "$(id -u)" -eq 0 ]; then
    collect_shell "$name" "$command"
  elif sudo -n true >/dev/null 2>&1; then
    {
      printf '$ sudo -n bash -c %q\n\n' "$command"
      timeout 45s sudo -n /usr/bin/bash -o pipefail -c "$command"
    } > "$work/$name.txt" 2>&1 || note "$name: privileged command failed or timed out"
  else
    note "$name: skipped; non-interactive privileged access was unavailable"
  fi
}

cat > "$work/README.txt" <<EOF
TB321FU Arch Linux support bundle
UTC collection time: $timestamp
Collector user: $target_user

This archive is intended for TB321FU debugging. It is collected offline and
redacted before compression. Review it before sharing. A missing section means
the command was unavailable, timed out, or required privileges not available
without an interactive prompt.
EOF

collect identity date --iso-8601=seconds
collect uname uname -a
collect os-release cat /etc/os-release
collect cmdline cat /proc/cmdline
collect modules lsmod
collect pci lspci -nnk
collect mounts findmnt -R /
collect storage lsblk -o NAME,PATH,SIZE,FSTYPE,LABEL,UUID,PARTLABEL,MOUNTPOINTS
collect addresses ip -details -br address
collect routes ip route show table all
collect nm-devices nmcli -f GENERAL,IP4,IP6 device show
collect nm-connections nmcli -f NAME,UUID,TYPE,DEVICE connection show
collect rfkill rfkill list
collect bluetooth-show bluetoothctl show
collect bluetooth-devices bluetoothctl devices
collect system-failed systemctl --failed --no-pager
collect system-analyze systemd-analyze
collect service-usb systemctl status tb321fu-usb-rescue.service --no-pager
collect service-bt-nap systemctl status tb321fu-bt-nap.service --no-pager
collect service-network systemctl status NetworkManager.service bluetooth.service sshd.service nftables.service --no-pager
collect user-failed systemctl --user --failed --no-pager
collect niri-outputs niri msg outputs
collect niri-inputs niri msg input-devices
collect audio-wpctl wpctl status
collect audio-pactl pactl list short
collect audio-playback aplay -l
collect audio-capture arecord -l
collect power-upower upower -d
collect brightness brightnessctl info

collect_shell firmware-tree \
  'find /usr/lib/firmware -maxdepth 5 -type f \( -path "*WCN7850*" -o -path "*ath12k*" \) -printf "%p %s bytes\n" 2>/dev/null | sort'
collect_shell usb-udc \
  'find /sys/class/udc -mindepth 1 -maxdepth 2 -printf "%y %p -> %l\n" 2>/dev/null | sort'
collect_shell usb-typec \
  'find /sys/class/typec -maxdepth 4 \( -type f -o -type l \) -print 2>/dev/null | sort | while read -r path; do printf "--- %s ---\n" "$path"; if [ -L "$path" ]; then readlink "$path"; elif [ -r "$path" ]; then head -c 4096 "$path"; printf "\n"; fi; done'
collect_privileged_shell usb-configfs \
  'find /sys/kernel/config/usb_gadget -maxdepth 6 -printf "%M %u:%g %p -> %l\n" 2>/dev/null | sort'
collect_shell network-rescue \
  'ip -details link show usb0 2>&1; ip -details link show bnep0 2>&1; networkctl status usb0 bnep0 2>&1 || true'
collect_shell power-supplies \
  'find /sys/class/power_supply -maxdepth 2 -type f -readable -print 2>/dev/null | sort | while read -r path; do printf "%s=" "$path"; head -c 4096 "$path"; printf "\n"; done'
collect_shell backlights \
  'find /sys/class/backlight -maxdepth 2 -type f -readable -print 2>/dev/null | sort | while read -r path; do printf "%s=" "$path"; head -c 4096 "$path"; printf "\n"; done'

collect_privileged_shell journal-current \
  'journalctl -b --no-pager -o short-precise'
collect_privileged_shell journal-previous \
  'journalctl -b -1 --no-pager -o short-precise'
collect_privileged_shell journal-hardware \
  'journalctl -b --no-pager -o short-precise | grep -Ei "ath12k|firmware|wlp|a600000|dwc3|ucsi|type.?c|gadget|ttyGS|usb0|bnep|bluetooth|niri|drm|dsi|pipewire|wireplumber|battery|charger|aw869"'

"$redactor" --tree "$work"
(
  cd "$work"
  find . -type f ! -name SHA256SUMS.txt -print0 | sort -z | xargs -0 sha256sum > SHA256SUMS.txt
)

archive_base="$destination/tb321fu-support-$timestamp"
if command -v zstd >/dev/null 2>&1; then
  archive="$archive_base.tar.zst"
  tar -C "$work" -cf - . | zstd -q -T0 -3 -o "$archive"
else
  archive="$archive_base.tar.gz"
  tar -C "$work" -czf "$archive" .
fi

if [ "$(id -u)" -eq 0 ] && id "$target_user" >/dev/null 2>&1; then
  chown "$target_user:$(id -gn "$target_user")" "$archive"
fi
chmod 0600 "$archive"
printf '%s\n' "$archive"
