#!/bin/sh
set -eu

root=
if [ "${1:-}" = --test-root ]; then
  [ "$#" -ge 3 ] || { echo "--test-root requires an absolute path and an action" >&2; exit 2; }
  root=$2
  shift 2
  case "$root" in
    /*) ;;
    *) echo "--test-root must be absolute" >&2; exit 2 ;;
  esac
fi

stock=$root/usr/lib/qt6/plugins/ksystemstats/ksystemstats_plugin_gpu.so
disabled=$stock.disabled-tb321fu-adreno

disable_stock() {
  [ ! -L "$stock" ] || { echo "refusing symlink stock GPU provider: $stock" >&2; return 1; }
  [ ! -L "$disabled" ] || { echo "refusing symlink disabled GPU provider: $disabled" >&2; return 1; }
  [ -f "$stock" ] || return 0
  [ ! -e "$disabled" ] || [ -f "$disabled" ] || {
    echo "refusing non-regular disabled GPU provider: $disabled" >&2
    return 1
  }
  temporary=$disabled.new.$$
  trap 'rm -f -- "$temporary"' EXIT HUP INT TERM
  mv -- "$stock" "$temporary"
  mv -f -- "$temporary" "$disabled"
  trap - EXIT HUP INT TERM
  [ ! -e "$stock" ]
  [ -f "$disabled" ]
}

restore_stock() {
  [ ! -L "$stock" ] || { echo "refusing symlink stock GPU provider: $stock" >&2; return 1; }
  [ ! -L "$disabled" ] || { echo "refusing symlink disabled GPU provider: $disabled" >&2; return 1; }
  if [ -e "$stock" ] || [ -L "$stock" ]; then
    [ ! -e "$disabled" ] && [ ! -L "$disabled" ] || {
      echo "refusing to overwrite active stock GPU provider while restoring $disabled" >&2
      return 1
    }
    return 0
  fi
  if [ -e "$disabled" ] || [ -L "$disabled" ]; then
    mv -- "$disabled" "$stock"
  fi
}

case "${1:-disable}" in
  disable) disable_stock ;;
  restore) restore_stock ;;
  *) echo "usage: ${0##*/} [--test-root /absolute/path] [disable|restore]" >&2; exit 2 ;;
esac
