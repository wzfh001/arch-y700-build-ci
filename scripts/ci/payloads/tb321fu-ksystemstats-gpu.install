post_install() {
  /usr/lib/tb321fu/disable-stock-ksystemstats-gpu disable
}

post_upgrade() {
  post_install
}

pre_remove() {
  /usr/lib/tb321fu/disable-stock-ksystemstats-gpu restore
}

post_remove() {
  local stock=/usr/lib/qt6/plugins/ksystemstats/ksystemstats_plugin_gpu.so
  local disabled=$stock.disabled-tb321fu-adreno
  if [[ ! -e $stock && ! -L $stock ]] && [[ -e $disabled || -L $disabled ]]; then
    mv -- "$disabled" "$stock"
  fi
}
